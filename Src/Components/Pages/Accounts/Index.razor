@page "/accounts"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@using RichillCapital.TraderStudio.Web.Services.Contracts.Accounts

@inject IApiService ApiService
@inject NavigationManager Navigation

<FluentDataGrid Items="accounts">
    <PropertyColumn Property="@(account => account.Id)"/>
    <PropertyColumn Property="@(account => account.Name)"/>
    
    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>        
</FluentDataGrid>

@code {
    private IQueryable<AccountResponse> accounts { get; set; } = new List<AccountResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagination = await ApiService.ListAccountsAsync(CancellationToken.None);
        accounts = pagination.Items.AsQueryable(); 
    }
}