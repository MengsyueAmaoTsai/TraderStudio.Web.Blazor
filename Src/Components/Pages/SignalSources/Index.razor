@page "/signal-sources"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@using RichillCapital.TraderStudio.Web.Services.Contracts.SignalSources

@inject IApiService ApiService
@inject NavigationManager Navigation

<FluentDataGrid TGridItem="SignalSourceResponse" Items="SignalSources">
    <PropertyColumn Property="@(source => source.Id)"/>
    <PropertyColumn Property="@(source => source.Name)"/>
    <PropertyColumn Property="@(source => source.Description)"/>

    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>
</FluentDataGrid>

@code {
    private IQueryable<SignalSourceResponse> SignalSources { get; set; } = 
        new List<SignalSourceResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagedResponse = await ApiService.ListSignalSourcesAsync(CancellationToken.None);
        SignalSources = pagedResponse.Items.AsQueryable(); 
    }

    private void NavigateToDetails(SignalSourceResponse source)
    {
        Navigation.NavigateTo($"/signal-source/{source.Id}");
    }
}