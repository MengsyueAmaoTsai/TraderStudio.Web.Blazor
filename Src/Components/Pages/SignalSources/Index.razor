@page "/signal-sources"
@rendermode InteractiveServer

@using RichillCapital.TraderStudio.Web.Services.Contracts.SignalSources

@inject IApiService ApiService
@inject NavigationManager Navigation

<FluentDataGrid Items="signalSources">
    <PropertyColumn Property="@(source => source.Id)"/>
    <PropertyColumn Property="@(source => source.Name)"/>
    <PropertyColumn Property="@(source => source.Description)"/>

    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>
</FluentDataGrid>

@code {
    private IQueryable<SignalSourceResponse> signalSources { get; set; } = new List<SignalSourceResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagination = await ApiService.ListSignalSourcesAsync(CancellationToken.None);
        signalSources = pagination.Items.AsQueryable(); 
    }

    private void NavigateToDetails(SignalSourceResponse source)
    {
        Navigation.NavigateTo($"/signal-source/{source.Id}");
    }
}