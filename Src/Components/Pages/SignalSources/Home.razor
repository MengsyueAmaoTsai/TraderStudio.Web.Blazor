@page "/signal-sources"

@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject IApiService ApiService

<FluentButton Appearance="@Appearance.Accent" @onclick="@(() => NavigateToCreatePage())">Create New</FluentButton>
    
<FluentDataGrid Items="@signalSources" TGridItem="SignalSourceResponse">
    <PropertyColumn Property="@(source => source.Id)" Title="ID" />
    <PropertyColumn Property="@(source => source.Name)" Title="Name" />

    <PropertyColumn Property="@(source => source.WinRate * 100)" Title="Win Rate (%)" Align="Align.End" />
    <PropertyColumn Property="@(source => source.Returns * 100)" Title="Returns (%)" Align="Align.End" />

    <TemplateColumn Title="Actions" Align="@Align.Center">
        <FluentButton aria-label="Details" IconEnd="@(new Icons.Regular.Size16.Eye())" @onclick="@(() => NavigateToSignalSourceDetails(context))"/>
        <FluentButton aria-label="Upload" IconEnd="@(new Icons.Regular.Size16.ArrowUpload())"/>
        <FluentButton aria-label="Delete" IconEnd="@(new Icons.Regular.Size16.Delete())"/>
    </TemplateColumn>
</FluentDataGrid>

@code {
    public required IQueryable<SignalSourceResponse> signalSources { get; set; } 

    protected override async Task OnInitializedAsync()
    {
        var pagedResponse = await ApiService.ListSignalSourcesAsync();

        signalSources = pagedResponse.Items.AsQueryable();
    }

    private void NavigateToCreatePage() => 
        Navigation.NavigateTo("/signal-sources/create");

    private void NavigateToSignalSourceDetails(SignalSourceResponse signalSource) =>
        Navigation.NavigateTo($"/signal-sources/{signalSource.Id}");
}