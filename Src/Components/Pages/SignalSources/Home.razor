@page "/signal-sources"
@using RichillCapital.TraderStudio.Web.Components.Pages.SignalSources

@inject HttpClient Client

<FluentButton Appearance="@Appearance.Accent">Create New</FluentButton>
    
<FluentDataGrid Items="@signalSources" TGridItem="SignalSourceResponse">
    <PropertyColumn Property="@(source => source.Id)" Title="ID" />
    <PropertyColumn Property="@(source => source.Name)" Title="Name" />
    <PropertyColumn Property="@(source => source.Description)" Title="Description" />

    <PropertyColumn Property="@(source => source.WinRate * 100)" Title="Win Rate (%)" />
    <PropertyColumn Property="@(source => source.Returns * 100)" Title="Returns (%)" />
</FluentDataGrid>

@code {
    public required IQueryable<SignalSourceResponse> signalSources { get; set; } 

    protected override async Task OnInitializedAsync()
    {
        var pagedResponse = await Client.ListSignalSourcesAsync();

        signalSources = pagedResponse.Items.AsQueryable();
    }
}