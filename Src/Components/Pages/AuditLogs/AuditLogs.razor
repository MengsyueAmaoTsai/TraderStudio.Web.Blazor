@page "/audit-logs"

@inject IApiService ApiService

<FluentDataGrid Items="@auditLogs" TGridItem="AuditLogResponse">
    <PropertyColumn Property="@(log => log.Id)" Title="ID" />
    <PropertyColumn Property="@(log => log.Time)" Title="Time" />
</FluentDataGrid>

@code {
    public required IQueryable<AuditLogResponse> auditLogs { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var pagedResponse = await ApiService.ListAuditLogsAsync();
        auditLogs = pagedResponse.Items.AsQueryable();
    }
}