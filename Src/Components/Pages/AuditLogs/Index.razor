@page "/audit-logs"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@using RichillCapital.TraderStudio.Web.Services.Contracts.AuditLogs

@inject IApiService ApiService
@inject NavigationManager Navigation

<FluentDataGrid Items="logs">
    <PropertyColumn Property="@(log => log.Id)"/>

    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>
</FluentDataGrid>

@code {
    private IQueryable<AuditLogResponse> logs { get; set; } = new List<AuditLogResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagination = await ApiService.ListAuditLogsAsync(CancellationToken.None);
        logs = pagination.Items.AsQueryable(); 
    }

    private void NavigateToDetails(AuditLogResponse log)
    {
        Navigation.NavigateTo($"/audit-logs/{log.Id}");
    }
}