@page "/instruments"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))


@using RichillCapital.TraderStudio.Web.Services.Contracts.Instruments

@inject IApiService ApiService
@inject NavigationManager Navigation

<FluentDataGrid Items="instruments">
    <PropertyColumn Property="@(instrument => instrument.Symbol)"/>
    <PropertyColumn Property="@(instrument => instrument.Description)"/>
    <PropertyColumn Property="@(instrument => instrument.Exchange)"/>
    <PropertyColumn Property="@(instrument => instrument.Type)"/>

    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>
</FluentDataGrid>

@code {
    private IQueryable<InstrumentResponse> instruments { get; set; } = new List<InstrumentResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagination = await ApiService.ListInstrumentsAsync(CancellationToken.None);
        instruments = pagination.Items.AsQueryable(); 
    }

    private void NavigateToDetails(InstrumentResponse instrument)
    {
        Navigation.NavigateTo($"/instruments/{instrument.Symbol}");
    }
}