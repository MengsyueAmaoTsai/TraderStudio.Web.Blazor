@page "/signals/{id}"

<h1>Signal Details</h1>

<FluentLabel>@Signal.Time.ToString("yyyy-MM-dd HH:mm:ss.fff")</FluentLabel>
<FluentLabel>@Signal.TradeType</FluentLabel>
<FluentLabel>@Signal.Symbol</FluentLabel>
<FluentLabel>@Signal.Quantity</FluentLabel>
<FluentLabel>@Signal.Price</FluentLabel>

@code {
    [Parameter]
    public string? Id { get; set; }

    public SignalModel Signal { get; set; } 

    protected override async Task OnInitializedAsync()
    {
        Signal = new SignalModel
        {
            Time = DateTime.Now,
            TradeType = "Buy",
            Symbol = "AAPL",
            Quantity = 100,
            Price = 150.00m,
        };
    }
}