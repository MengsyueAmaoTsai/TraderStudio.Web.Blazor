@page "/orders/create"
@rendermode InteractiveServer

@using RichillCapital.TraderStudio.Web.Services.Contracts.Orders
@using RichillCapital.TraderStudio.Web.Services.Contracts.Accounts

@inject ILogger<Create> Logger
@inject IApiService ApiService

<EditForm Model="request" OnValidSubmit="@SubmitOrderAsync">
    <FluentTextField @bind-Value="request.AccountId" Label="Account"/>
    <FluentTextField @bind-Value="request.TradeType" Label="Trade Type"/>
    <FluentTextField @bind-Value="request.OrderType" Label="Order Type"/>
    <FluentTextField @bind-Value="request.Symbol" Label="Symbol"/>
    <FluentNumberField @bind-Value="request.Quantity" Label="Quantity"/>
    <FluentNumberField @bind-Value="request.Price" Label="Price" />
    <FluentTextField @bind-Value="request.TimeInForce" Label="Time In Force"/>
    <FluentButton Type="ButtonType.Submit" Appearance="Appearance.Accent">Submit</FluentButton>
</EditForm>

@code {
    [SupplyParameterFromForm]
    private CreateOrderRequest request { get; set; } = new()
    {
        AccountId = "1",
        TradeType = "Buy",
        OrderType = "Market",
        Symbol = "AAPL",
        Quantity = 100,
        Price = 100,
        TimeInForce = "GTC",
    };
    
    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }   

    private async Task SubmitOrderAsync()
    {
        Logger.LogInformation("Creating order {@Order}", request);
        var newOrderId = await ApiService.CreateOrderAsync(
            request, 
            CancellationToken.None);  

        Logger.LogInformation("Order created with id {OrderId}", newOrderId);
    }
}