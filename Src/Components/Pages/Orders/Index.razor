@page "/orders"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@using RichillCapital.TraderStudio.Web.Services.Contracts.Orders

@inject IApiService ApiService
@inject NavigationManager Navigation


<FluentDataGrid Items="orders">
    <PropertyColumn Property="@(order => order.Id)"/>
    <PropertyColumn Property="@(order => order.TradeType)"/>
    <PropertyColumn Property="@(order => order.Type)"/>
    <PropertyColumn Property="@(order => order.Symbol)"/>
    <PropertyColumn Property="@(order => order.Quantity)"/>
    <PropertyColumn Property="@(order => order.Price)"/>
    <PropertyColumn Property="@(order => order.TimeInForce)"/>

    <PropertyColumn Property="@(order => order.AccountId)"/>

    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>
</FluentDataGrid>

@code {
    private IQueryable<OrderResponse> orders { get; set; } = new List<OrderResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagination = await ApiService.ListOrdersAsync(CancellationToken.None);
        orders = pagination.Items.AsQueryable(); 
    }
}