@page "/users"
@rendermode @(new InteractiveAutoRenderMode(prerender: false))

@using RichillCapital.TraderStudio.Web.Services.Contracts.Users

@inject IApiService ApiService
@inject NavigationManager Navigation

<FluentDataGrid Items="users">
    <PropertyColumn Property="@(user => user.Id)"/>
    <PropertyColumn Property="@(user => user.Email)"/>
    <PropertyColumn Property="@(user => user.Name)"/>

    <TemplateColumn>
        <FluentButton Appearance="Appearance.Accent">Details</FluentButton> 
    </TemplateColumn>
</FluentDataGrid>

@code {
    private IQueryable<UserResponse> users { get; set; } = new List<UserResponse>().AsQueryable();

    protected override async Task OnInitializedAsync()
    {
        var pagination = await ApiService.ListUsersAsync(CancellationToken.None);
        users = pagination.Items.AsQueryable(); 
    }

    private void NavigateToDetails(UserResponse user)
    {
        Navigation.NavigateTo($"/users/{user.Id}");
    }
}